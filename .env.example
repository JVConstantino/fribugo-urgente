# ===========================================
# Friburgo Urgente - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env no repositório.

# ----- Appwrite -----
# URL base do servidor Appwrite
VITE_APPWRITE_ENDPOINT=https://database.friburgourgente.com.br/v1

# ID do projeto no Appwrite
VITE_APPWRITE_PROJECT_ID=69f7b8ed000657470871

# ID do banco de dados criado no Appwrite
VITE_APPWRITE_DATABASE_ID=friburgourgente

# ID da coleção de artigos
VITE_APPWRITE_ARTICLES_COLLECTION_ID=articles

# ID da coleção de categorias
VITE_APPWRITE_CATEGORIES_COLLECTION_ID=categories

# ID da coleção de newsletter
VITE_APPWRITE_NEWSLETTER_COLLECTION_ID=newsletter

# ID do bucket de armazenamento (imagens de capa)
VITE_APPWRITE_STORAGE_BUCKET_ID=covers

# ID da coleção de anúncios
VITE_APPWRITE_ADS_COLLECTION_ID=ads

# ID da coleção de grupos de WhatsApp
VITE_APPWRITE_GROUPS_COLLECTION_ID=whatsapp_groups

# ID da coleção de notícias enviadas por internautas
VITE_APPWRITE_USER_NEWS_COLLECTION_ID=user_news

# ID da coleção de configurações de IA
VITE_APPWRITE_AI_CONFIG_COLLECTION_ID=ai_config

# ID da coleção de configurações do sistema
VITE_APPWRITE_SYSTEM_SETTINGS_COLLECTION_ID=system_settings

# ID do bucket de mídia de internautas (fotos/vídeos)
VITE_APPWRITE_USER_MEDIA_BUCKET_ID=user_media

# ID da coleção de popups
VITE_APPWRITE_POPUPS_COLLECTION_ID=popups

# ----- hCaptcha -----
# Site key do hCaptcha (visível no frontend)
VITE_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key_here