# ===========================================
# Friburgo Urgente - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env no repositório.

# ----- Appwrite -----
# URL base do servidor Appwrite
VITE_APPWRITE_ENDPOINT=https://friburgourgente-database.veuxld.easypanel.host/v1

# ID do projeto no Appwrite
VITE_APPWRITE_PROJECT_ID=69f7b8ed000657470871

# ID do banco de dados criado no Appwrite
VITE_APPWRITE_DATABASE_ID=friburgourgente

# ID da coleção de artigos
VITE_APPWRITE_ARTICLES_COLLECTION_ID=articles

# ID da coleção de categorias
VITE_APPWRITE_CATEGORIES_COLLECTION_ID=categories

# ID da coleção de newsletter
VITE_APPWRITE_NEWSLETTER_COLLECTION_ID=newsletter

# ID do bucket de armazenamento (imagens de capa)
VITE_APPWRITE_STORAGE_BUCKET_ID=covers

# ID da coleção de anúncios
VITE_APPWRITE_ADS_COLLECTION_ID=ads

# ID da coleção de grupos de WhatsApp
VITE_APPWRITE_GROUPS_COLLECTION_ID=whatsapp_groups