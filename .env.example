# ===========================================
# Friburgo Urgente - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env no repositório.

# ----- Appwrite -----
# URL base do servidor Appwrite (ex: https://cloud.appwrite.io/v1)
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# ID do projeto no Appwrite
VITE_APPWRITE_PROJECT_ID=seu_project_id_aqui

# ID do banco de dados criado no Appwrite
VITE_APPWRITE_DATABASE_ID=seu_database_id_aqui

# ID da coleção de artigos
VITE_APPWRITE_ARTICLES_COLLECTION_ID=seu_articles_collection_id_aqui

# ID da coleção de categorias
VITE_APPWRITE_CATEGORIES_COLLECTION_ID=seu_categories_collection_id_aqui

# ID da coleção de newsletter
VITE_APPWRITE_NEWSLETTER_COLLECTION_ID=seu_newsletter_collection_id_aqui

# ID do bucket de armazenamento (imagens de capa)
VITE_APPWRITE_STORAGE_BUCKET_ID=seu_storage_bucket_id_aqui